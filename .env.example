# === Network ===
AI_SERVER_HOST=10.20.30.185
RPI_HOST=10.20.30.180

# === MCP Server (Home Assistant) ===
MCP_SERVER_URL=https://url-to-mcp

# === Home Assistant WebSocket (used by stream_camera for WebRTC signaling) ===
# Leave both empty to disable live camera streaming. The token must be a
# Long-Lived Access Token created in HA's user profile.
HA_URL=
HA_TOKEN=

# === go2rtc sidecar (used by stream_rtsp for arbitrary RTSP -> WebRTC) ===
# Defaults to the bundled sidecar reachable via host.docker.internal.
# Override only if you run go2rtc elsewhere.
# GO2RTC_URL=http://host.docker.internal:1984

# === Wake Word ===
WAKE_WORD=hey homie

# === Ollama ===
OLLAMA_HOST=http://10.20.30.185:11434
OLLAMA_MODEL=gpt-oss:20b
# Context window size in tokens (larger = more memory, more VRAM usage)
OLLAMA_NUM_CTX=32768
# Max tokens to generate per response
OLLAMA_NUM_PREDICT=512

# === Auto Theme (switches RPi UI at dusk/dawn from HA sun.sun) ===
AUTO_THEME=true
THEME_DAY=birch       # used during the day (one of: dark, birch, odyssey, japandi)
THEME_NIGHT=dark      # used at night

# === Wyoming TTS (e.g., whisper-tts) ===
WYOMING_TTS_HOST=10.20.30.185
WYOMING_TTS_PORT=10300
# WYOMING_TTS_VOICE=  # Voice name (empty = server default)

# === Long-term Memory (Shodh) ===
# MEMORY_URL=http://shodh-memory:3030  # default, auto-discovered via compose
# MEMORY_USER_ID=hal-default

# === Speech-to-Text ===
# STT_ENGINE: "whisper" (default) or "nemotron"
STT_ENGINE=whisper
# STT_MODEL: model name/size (optional, uses sensible defaults)
#   whisper:   large-v3-turbo, large-v3, medium, base, small, tiny
#   nemotron:  nvidia/parakeet-tdt-0.6b-v2, nvidia/parakeet-ctc-1.1b
# STT_MODEL=

# === Audio ===
AUDIO_DEVICE=default
SAMPLE_RATE=48000
CHANNELS=1
CHUNK_SIZE=4096

# === Web UI ===
WEB_PORT=8080

# === Kiosk screenshot via Chrome DevTools Protocol ===
# audio_streamer captures the kiosk page through CDP and forwards
# the JPEG to the AI server. The kiosk Chromium must be launched
# with --remote-debugging-port=9222 and --remote-debugging-address=0.0.0.0
# (so the audio_streamer container can reach it across the bridge).
# CHROMIUM_DEBUG_URL=http://host.docker.internal:9222
# SNAPSHOT_INTERVAL_S=60

# === MQTT (exposes HAL as a Home Assistant device via auto-discovery) ===
# Leave MQTT_BROKER_HOST empty to disable.
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
HAL_DEVICE_ID=hal-default
HAL_DEVICE_NAME=HAL

# === Sendspin (Music Assistant multi-room audio) ===
# The sendspin sidecar registers a player in MA called
# "${HAL_DEVICE_NAME} Speaker". Set the resulting entity_id below to
# enable hardware-volume-button redirection (when music plays, the
# Anker buttons drive MA volume instead of HAL TTS) and the optional
# pause-during-TTS fallback. Leave empty to disable both.
SENDSPIN_PLAYER_ENTITY=
# Set to true to pause MA when HAL is about to speak (Shape C). Off
# by default — the recommended path is Pulse role-ducking. See
# rpi/sendspin/README.md for the one-time host Pulse config.
SENDSPIN_PAUSE_DURING_TTS=false
SENDSPIN_LOG_LEVEL=INFO
