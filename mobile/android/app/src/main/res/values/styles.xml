<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Dark window background so the status/navigation-bar strip the
             WebView doesn't cover stays dark in BOTH light and dark system
             modes. Without this, DayNight paints it white in light mode (the
             white-letterbox bug on the Pixel Tablet). windowBackground is the
             one that actually applies on targetSdk 35+ (edge-to-edge); the
             *Color items are defensive for older targets. -->
        <item name="android:windowBackground">@color/palWindowBg</item>
        <!-- Transparent system bars so the WebView fills the whole screen and
             the icons float on top (game-style), instead of MIUI painting an
             opaque dark strip. windowBackground stays dark so any uncovered
             pixel is dark, never the white-letterbox bug. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>