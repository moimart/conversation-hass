# PAL Android release/upload signing.
# Copy to mobile/android/keystore.properties (gitignored) and fill in, then
# `./gradlew bundleRelease` produces a signed AAB for Google Play.
#
# Create the upload keystore ONCE, then BACK IT UP (the .jks + these passwords):
# losing the upload key means resetting it via Google Play support.
#
#   cd mobile/android
#   keytool -genkeypair -v -keystore pal-upload-key.jks -alias pal-upload \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -dname "CN=PAL, O=Kikkei Labs UG, C=DE"
#
# keytool prompts for a keystore password; when it asks for the key password you
# can press Enter to reuse the keystore password. Put whatever you chose below.
# Paths are relative to mobile/android/.

storeFile=pal-upload-key.jks
storePassword=CHANGE_ME
keyAlias=pal-upload
keyPassword=CHANGE_ME
