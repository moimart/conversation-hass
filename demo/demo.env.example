# PAL demo instance — copy to demo/demo.env and fill in. Gitignored.
# Run: docker compose -f docker-compose.demo.yml --env-file demo/demo.env \
#                     --profile tunnel up -d

# --- Cloudflare tunnel (only needed with `--profile tunnel`) ------------------
# Token for a dashboard-managed tunnel whose demo.hal.martinez.sh public
# hostname points at http://gateway:8766. Leave empty to run without the bundled
# tunnel (then point your existing tunnel at http://127.0.0.1:8767).
DEMO_TUNNEL_TOKEN=

# --- LLM backend on 185 -------------------------------------------------------
# Must be a model your ollama already has (ideally pinned with keep_alive=-1).
# gemma4:e4b is what PAL prod uses (already warm on 185).
DEMO_OLLAMA_MODEL=gemma4:e4b
# DEMO_OLLAMA_HOST=http://10.20.30.185:11434

# --- Wyoming TTS on 185 -------------------------------------------------------
# Confirm the real port (CLAUDE.md notes 10300; compose default elsewhere 10200).
DEMO_WYOMING_TTS_PORT=10300
# Demo speaks in the Moises voice by default (a named voice on the omnivoice
# server). Override here if desired.
# DEMO_WYOMING_TTS_VOICE=Moises

# --- STT service on 185 -------------------------------------------------------
# DEMO_STT_REMOTE_URL=http://10.20.30.185:8770

# --- Misc ---------------------------------------------------------------------
# DEMO_PAIR_CODE=000000
# DEMO_GATEWAY_URL=https://demohal.martinez.sh
# DEMO_RATE_LIMIT_RPM=120
